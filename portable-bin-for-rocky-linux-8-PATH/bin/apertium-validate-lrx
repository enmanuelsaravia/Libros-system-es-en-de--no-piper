#!/bin/bash
if [[ $# != 1 ]]; then
    echo "USAGE: $(basename "$0") <input_file>"
    exit 1
fi

FILE1=$1

if [[ ! -e $FILE1 ]]; then
    echo "ERROR: '$1' file not found"
    exit 1
fi
xmllint --dtdvalid "/home/user/Libros-system-es-en-de--no-piper/portable-bin-for-rocky-linux-8-PATH"/share/apertium-lex-tools/lrx.dtd --noout "$FILE1"
