#!/bin/bash
case $# in
  2)
    INFILE=$1
    OUTFILE=$2
    ;;
  *)
    echo "USAGE: apertium-metalrx-to-lrx INFILE OUTFILE";
    exit 1;
esac

xsltproc /home/user/Libros-system-es-en-de--no-piper/portable-bin-for-rocky-linux-8-PATH/share/apertium/metalrx-to-lrx.xslt "$INFILE" > "$OUTFILE.tmp"
xmllint --format "$OUTFILE.tmp" > "$OUTFILE"
rm -f "$OUTFILE.tmp"
